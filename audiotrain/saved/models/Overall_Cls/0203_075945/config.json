{
    "name": "Overall_Cls",
    "n_gpu": 1,
    "arch": {
        "type": "MentalHealthResNet",
        "args": {
            "num_classes": 2
        }
    },
    "data_loader": {
        "type": "MentalHealthDataLoader",
        "args": {
            "data_dir": "/data2/lx/mental/audio/pngs",
            "csv_path": "/data2/lx/mental/audio/data.csv",
            "task_name": "overall",
            "batch_size": 32,
            "shuffle": true,
            "validation_split": 0.2,
            "num_workers": 4
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "cross_entropy",
    "metrics": [
        "accuracy",
        "f1_macro",
        "recall_macro"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 100,
        "save_dir": "saved/",
        "save_period": 10,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 10,
        "tensorboard": true
    }
}